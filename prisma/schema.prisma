// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash        String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  
  // Remediation Settings
  autoPRCreation         Boolean   @default(false)
  autoVerification       Boolean   @default(true)
  manualApprovalRequired Boolean   @default(true)
  confidenceThreshold    Int       @default(85)

  repositories   Repository[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repository {
  id            String   @id @default(cuid())
  githubId      Int?     @unique
  userId        String
  name          String
  fullName      String
  owner         String?
  defaultBranch String
  private       Boolean
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows Workflow[]
  incidents Incident[]
  patches   Patch[]
}

model Workflow {
  id               String   @id @default(cuid())
  repositoryId     String
  githubId         Int?     @unique
  name             String
  path             String
  state            String?
  createdAt        DateTime @default(now())

  repository   Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  workflowRuns WorkflowRun[]
}

model WorkflowRun {
  id           String    @id @default(cuid())
  workflowId   String
  githubRunId  BigInt?   @unique
  status       String
  conclusion   String?
  branch       String?
  commitSha    String?
  actor        String?
  duration     Int?
  htmlUrl      String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  workflow   Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  incidents  Incident[]
  logEntries LogEntry[]
  analyses   Analysis[]
  patches    Patch[]
  issues     Issue[]
}

model Incident {
  id            String   @id @default(cuid())
  repositoryId  String
  workflowRunId String
  title         String
  severity      String
  status        String
  createdAt     DateTime @default(now())

  repository  Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  events      IncidentEvent[]
  issues      Issue[]
}

model IncidentEvent {
  id            String   @id @default(cuid())
  incidentId    String
  status        String
  details       String?  @db.Text
  patchId       String?
  prNumber      Int?
  workflowRunId String?
  createdAt     DateTime @default(now())

  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model LogEntry {
  id            String   @id @default(cuid())
  workflowRunId String
  rawLogs       String   @db.Text
  createdAt     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
}

model Issue {
  id            String   @id @default(cuid())
  incidentId    String
  workflowRunId String
  type          String   @default("FAILURE") // FAILURE, WARNING, RECOMMENDATION
  severity      String
  category      String
  file          String
  line          Int?
  title         String
  rootCause     String   @db.Text
  manualFix     String   @db.Text
  aiFixSummary  String?  @db.Text
  confidence    Int
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  incident    Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  fixes       IssueFix[]
  patches     IssuePatch[]
}

model IssueFix {
  id           String   @id @default(cuid())
  issueId      String
  explanation  String   @db.Text
  suggestedFix String   @db.Text
  confidence   Int
  createdAt    DateTime @default(now())

  issue     Issue           @relation(fields: [issueId], references: [id], onDelete: Cascade)
  approvals IssueApproval[]
}

model IssuePatch {
  id            String   @id @default(cuid())
  issueId       String
  diff          String   @db.Text
  affectedFiles String[]
  status        String   @default("GENERATED")
  createdAt     DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model IssueApproval {
  id         String   @id @default(cuid())
  issueFixId String
  status     String   @default("PENDING")
  feedback   String?  @db.Text
  createdAt  DateTime @default(now())

  issueFix IssueFix @relation(fields: [issueFixId], references: [id], onDelete: Cascade)
}

model Analysis {
  id            String   @id @default(cuid())
  incidentId    String?
  workflowRunId String
  rootCause     String   @db.Text
  explanation   String   @db.Text
  suggestedFix  String   @db.Text
  confidence    Int
  rawLogs       String?  @db.Text
  createdAt     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  patches     Patch[]
}

model Patch {
  id                String   @id @default(cuid())
  analysisId        String
  workflowRunId     String
  repositoryId      String
  title             String
  description       String   @db.Text
  patchType         String
  diff              String   @db.Text
  filesChanged      String // Deprecated, use affectedFiles
  affectedFiles     String[]
  confidence        Int
  status            String   @default("GENERATED")
  prNumber          Int?
  prUrl             String?
  verifiedAt        DateTime?
  verificationRunId String?
  verificationStatus String?
  dependencyChanges Boolean  @default(false)
  lockfileGenerated Boolean  @default(false)
  packageManager    String?
  executedCommands  String[]
  artifacts         String[]
  remediationLogs   String?  @db.Text
  verificationResult String?
  verificationOutput String?  @db.Text
  buildError        String?  @db.Text
  retryCount        Int      @default(0)
  validatorResult   String?
  selfReviewResult  String?
  detectedWorkspace String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  analysis      Analysis    @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  repository    Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  verificationAttempts VerificationAttempt[]
}

model VerificationAttempt {
  id              String   @id @default(cuid())
  patchId         String
  attemptNumber   Int
  scope           String
  commands        String[]
  cwd             String[]
  stdout          String?  @db.Text
  stderr          String?  @db.Text
  exitCode        Int?
  duration        Int?
  confidenceScore Int?
  status          String
  rationale       String?  @db.Text
  localizedFailure String? @db.Text
  generatedDiff   String?  @db.Text
  reasoning       String?  @db.Text
  createdAt       DateTime @default(now())

  patch Patch @relation(fields: [patchId], references: [id], onDelete: Cascade)
}

